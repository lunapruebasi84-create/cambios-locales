rules_version='2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function currentUserPath() {
      return /databases/$(database)/documents/usuarios/$(request.auth.uid);
    }

    function currentUserData() {
      return get(currentUserPath()).data;
    }

    function isActiveUser() {
      return isSignedIn()
        && exists(currentUserPath())
        && currentUserData().status == "active";
    }

    function isAdmin() {
      return isActiveUser()
        && currentUserData().isAdmin == true;
    }

    function hasPermission(permission) {
      return isActiveUser()
        && (
          isAdmin()
          || (
            currentUserData().permissions is list
            && currentUserData().permissions.hasAny([permission])
          )
        );
    }

    function hasPatientAttachmentFields(patientId) {
      return request.resource.data.nombre is string
        && request.resource.data.tipo is string
        && request.resource.data.url is string
        && request.resource.data.storagePath is string
        && request.resource.data.storagePath.matches('^pacientes/' + patientId + '/.+');
    }

    function isSafeSelfUserCreate(userId) {
      return isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.isAdmin != true
        && (
          !request.resource.data.keys().hasAny(["permissions"])
          || request.resource.data.permissions.size() == 0
        )
        && (
          !request.resource.data.keys().hasAny(["roleIds"])
          || request.resource.data.roleIds.size() == 0
        );
    }

    function isSafeSelfUserUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "displayName",
        "photoURL",
        "phone",
        "lastLoginAt",
        "updatedAt"
      ]);
    }

    match /roles/{roleId} {
      allow read: if hasPermission("roles.view");

      allow create: if hasPermission("roles.create")
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.permissions is list
        && request.resource.data.isSystem == false;

      allow update: if hasPermission("roles.update")
        && resource.data.isSystem != true;

      allow delete: if hasPermission("roles.delete")
        && resource.data.isSystem != true;
    }

    match /pacientes/{patientId} {
      allow read, write: if isSignedIn();

      match /historial/{entryId} {
        allow read, write: if isSignedIn();
      }

      match /odontograma/{odontogramId} {
        allow read, write: if isSignedIn();
      }

      match /adjuntos/{attachmentId} {
        allow read, write: if isSignedIn() && hasPatientAttachmentFields(patientId);
      }
    }

    match /servicios/{serviceId} {
      allow read, write: if isSignedIn();
    }

    match /cotizaciones/{cotizacionId} {
      allow read, write: if isSignedIn();
    }

    match /paquetes/{paqueteId} {
      allow read, write: if isSignedIn();
    }

    match /usuarios/{userId} {
      allow read: if request.auth.uid == userId
        || hasPermission("users.view")
        || hasPermission("roles.view")
        || hasPermission("roles.update")
        || hasPermission("roles.assign");

      allow create: if isSafeSelfUserCreate(userId)
        || hasPermission("users.create");

      allow update: if (
          request.auth.uid == userId
          && isSafeSelfUserUpdate()
        )
        || hasPermission("users.update")
        || hasPermission("roles.assign")
        || hasPermission("roles.update");

      allow delete: if hasPermission("users.delete");

      match /sesiones/{sessionId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      match /dispositivos/{deviceId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}